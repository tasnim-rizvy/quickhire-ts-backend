{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ],
  "env": {
    "MONGODB_URI": "@mongodb-uri",
    "ADMIN_SECRET_KEY": "@admin-secret-key",
    "FRONTEND_URL": "@frontend-url"
  }
}
